{
  "expo": {
    "name": "SSBFY",
    "slug": "ssbfy-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/new_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ayoobbhat.ssbfy",
      "versionCode": 6,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/new_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/new_icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2e3b7e02-f1df-461b-9d2a-071b1481d8d1"
      }
    },
    "owner": "ayoobbhat",
    "plugins": [
      "expo-web-browser",
      "./plugins/withAdiRegistration",
      "@sentry/react-native"
    ]
  }
}
