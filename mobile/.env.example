# Expo public env — copy to `.env` in this folder.
# EXPO_PUBLIC_* are inlined at build time; restart Expo after changes.
# https://docs.expo.dev/guides/environment-variables/

# Backend API (HTTPS in production). Falls back to baked-in prod URL if unset.
EXPO_PUBLIC_API_BASE_URL=

# Sentry — crash/error reporting for React Native (leave empty to disable)
EXPO_PUBLIC_SENTRY_DSN=

# Set to 1 to send Sentry events while developing (__DEV__). Default: off in dev.
EXPO_PUBLIC_SENTRY_ENABLE_IN_DEV=
