NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/jkssb_prep
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Razorpay (payments) — never commit real secrets
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Default create-order amount in whole INR if request body omits amount
RAZORPAY_DEFAULT_AMOUNT_INR=99

# Cloudinary (PDF storage) — never commit real secrets
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Max PDF upload size in MB (enforced at the multer layer before upload)
PDF_MAX_SIZE_MB=25

# Free mock tests per device (non-premium). Device + server enforced.
FREE_TEST_LIMIT=3
