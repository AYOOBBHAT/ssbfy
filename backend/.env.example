NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/jkssb_prep
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Razorpay (payments) — never commit real secrets
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Default create-order amount in whole INR if request body omits amount
RAZORPAY_DEFAULT_AMOUNT_INR=99
