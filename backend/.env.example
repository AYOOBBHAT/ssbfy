NODE_ENV=development
PORT=5000

# Structured logging (pino): trace | debug | info | warn | error | fatal | silent
# Production default is info if unset.
LOG_LEVEL=

# Comma-separated web app origins (production CORS). No *; leave empty in local dev.
# Example: https://ssbfy.vercel.app,https://your-admin.vercel.app
ALLOWED_ORIGINS=

MONGODB_URI=mongodb://127.0.0.1:27017/jkssb_prep
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# One-time production MongoDB index sync — set to true once after deploy, then unset/false
SYNC_INDEXES=false

# Razorpay (payments) — never commit real secrets
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (Dashboard → Webhooks) — verifies X-Razorpay-Signature on POST /api/payments/webhook
RAZORPAY_WEBHOOK_SECRET=
# Default create-order amount in whole INR if request body omits amount
RAZORPAY_DEFAULT_AMOUNT_INR=99

# Supabase (PDF notes — private Storage bucket; server signs short-lived URLs; service role only)
# Dashboard: set bucket to NOT public, or signed URLs do not protect content.
# URLs must be the project URL, e.g. https://<ref>.supabase.co (Settings → API).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=pdf-notes
# Max PDF upload size in MB (enforced at multer before temp write / Supabase upload)
PDF_MAX_SIZE_MB=25
# Signed download URL lifetime in seconds (clamped 30–120)
PDF_SIGNED_URL_TTL_SECONDS=90

# Upstash Redis REST (shared rate limits). https://console.upstash.com
# Leave unset in local dev to disable rate limiting (except webhook fail-open path).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Free mock tests per device (non-premium). Device + server enforced.
FREE_TEST_LIMIT=3

# Resend — password reset OTP emails (server only; never expose API key to clients)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
APP_NAME=
